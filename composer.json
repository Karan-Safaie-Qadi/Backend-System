{
    "name": "karan-safaie-qadi/backend-system",
    "description": "A complete OOP backend management system built on PDO-Module. Full-featured PHP framework for users, products, articles, access control, and more.",
    "type": "library",
    "license": "MIT",
    "keywords": ["php", "backend", "pdo", "auth", "users", "products", "articles", "cms", "rest", "api", "management-system"],
    "homepage": "https://github.com/Karan-Safaie-Qadi/Backend-System",
    "support": {
        "issues": "https://github.com/Karan-Safaie-Qadi/Backend-System/issues",
        "source": "https://github.com/Karan-Safaie-Qadi/Backend-System"
    },
    "require": {
        "php": ">=7.4",
        "karan-safaie-qadi/pdo-module": "^1.0",
        "phpmailer/phpmailer": "^6.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Karan Safaie Qadi",
            "email": "karensefaie@gmail.com",
            "homepage": "https://github.com/Karan-Safaie-Qadi"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
